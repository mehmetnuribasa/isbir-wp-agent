# Gemini AI (AI Studio API Key)
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_ENABLE_CORRELATION_IDS=true

# Knowledge base
KNOWLEDGE_BASE_PATH=data/knowledge-base.txt

# Environment
ENVIRONMENT=development

# Message Queue
QUEUE_MAX_SIZE=1000
QUEUE_WORKER_COUNT=3
QUEUE_PROCESSING_TIMEOUT=60

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=30
USER_MESSAGE_DEBOUNCE_SECONDS=2.0

# Business Hours (Turkey timezone)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
BUSINESS_TIMEZONE=Europe/Istanbul
BUSINESS_DAYS=0,1,2,3,4
